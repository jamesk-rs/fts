# Time Sync Configuration - SLAVE 6 role (ESP32-S3 with WS2812 RGB LED)
CONFIG_FTS_ROLE_SLAVE=y

# MQTT device ID for slave and enable RL control
CONFIG_FTS_MQTT_DEVICE_ID="slave6"
CONFIG_FTS_MQTT_ENABLE_CONTROL=y

# WS2812 RGB LED on GPIO 48
CONFIG_FTS_LED_GPIO=48
CONFIG_FTS_LED_WS2812=y

# MCPWM pulse output on GPIO 14
CONFIG_FTS_PULSE_MCPWM_GPIO=14
