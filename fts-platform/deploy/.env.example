# FTS Platform Cloud Deployment Configuration
# Copy this to .env and customize before deployment

# InfluxDB Configuration
INFLUX_ADMIN_USERNAME=admin
INFLUX_ADMIN_PASSWORD=CHANGE_ME_secure_password_here
INFLUX_ADMIN_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32
INFLUX_ORG=fts
INFLUX_BUCKET=fts

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_secure_password_here

# MQTT Configuration (set to false for production with auth)
MQTT_ALLOW_ANONYMOUS=true
# MQTT_USERNAME=fts
# MQTT_PASSWORD=CHANGE_ME_mqtt_password

# Network Configuration
# Set to your LXC container's IP or hostname
FTS_HOST=0.0.0.0

# Docker GID (run: stat -c '%g' /var/run/docker.sock inside LXC)
DOCKER_GID=999
