# FTS Platform Environment Variables
# Copy to .env and customize for your deployment

# InfluxDB Configuration
INFLUX_ADMIN_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32
INFLUX_ADMIN_PASSWORD=CHANGE_ME_secure_password
INFLUX_ADMIN_USERNAME=admin
INFLUX_ORG=feenix
INFLUX_BUCKET=fts

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=admin

# Docker GID (run: stat -c '%g' /var/run/docker.sock)
# DOCKER_GID=124

# MQTT Configuration (for split-cloud and split-local profiles)
MQTT_USERNAME=fts
MQTT_PASSWORD=CHANGE_ME_mqtt_password

# Bridge Configuration (for split-local profile only)
# MQTT_BRIDGE_HOST=<cloud-ip>
# MQTT_BRIDGE_PORT=1883
