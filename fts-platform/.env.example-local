# FTS Platform - Split-Local Profile
# Copy to .env and customize for your deployment
#
# This profile runs only Mosquitto locally, bridging to a cloud instance.
# InfluxDB/Grafana run on the cloud side.

# Docker GID (run: stat -c '%g' /var/run/docker.sock)
DOCKER_GID=124

# Docker Compose Profile (must match deployment command)
COMPOSE_PROFILES=split-local

# MQTT Bridge Configuration (required)
# These should match the credentials on your cloud Mosquitto instance
MQTT_USERNAME=fts
MQTT_PASSWORD=YOUR_CLOUD_MQTT_PASSWORD

# Cloud MQTT Broker (required)
MQTT_BRIDGE_HOST=YOUR_CLOUD_IP_OR_HOSTNAME
MQTT_BRIDGE_PORT=1883
