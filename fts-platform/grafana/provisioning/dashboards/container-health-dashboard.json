        "options": [],
        "query": "from(bucket: \"fts\")\n  |> range(start: 0)\n  |> filter(fn: (r) => r._measurement == \"experiments\")\n  |> filter(fn: (r) => r.type == \"start\")\n  |> keep(columns: [\"experiment\"])\n  |> distinct(column: \"experiment\")",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 0,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "definition": "Experiment Start",
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "name": "exp_start",
        "options": [],
        "query": "import \"array\"\n\nexpData = from(bucket: \"fts\")\n  |> range(start: 0)\n  |> filter(fn: (r) => r._measurement == \"experiments\")\n  |> filter(fn: (r) => r.experiment == \"${experiment}\")\n  |> filter(fn: (r) => r.type == \"start\")\n  |> last()\n  |> map(fn: (r) => ({_value: string(v: uint(v: r._time) / uint(v: 1000000)), priority: 0}))\n\nfallback = array.from(rows: [{_value: \"now-5m\", priority: 1}])\n\nunion(tables: [expData, fallback])\n  |> group()\n  |> sort(columns: [\"priority\"])\n  |> limit(n: 1)\n  |> keep(columns: [\"_value\"])",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": true,
        "sort": 0,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "definition": "Experiment End",
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "name": "exp_end",
        "options": [],
        "query": "import \"array\"\n\nexpData = from(bucket: \"fts\")\n  |> range(start: 0)\n  |> filter(fn: (r) => r._measurement == \"experiments\")\n  |> filter(fn: (r) => r.experiment == \"${experiment}\")\n  |> filter(fn: (r) => r.type == \"stop\")\n  |> last()\n  |> map(fn: (r) => ({_value: string(v: uint(v: r._time) / uint(v: 1000000)), priority: 0}))\n\nfallback = array.from(rows: [{_value: \"now\", priority: 1}])\n\nunion(tables: [expData, fallback])\n  |> group()\n  |> sort(columns: [\"priority\"])\n  |> limit(n: 1)\n  |> keep(columns: [\"_value\"])",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": true,
        "sort": 0,
