      "title": "Edge Records by Type (edges, 10s windows)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "a_count = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"edges\" and r[\"_field\"] == \"channel_a_ns\")\n  |> aggregateWindow(every: 10s, fn: count, createEmpty: false)\n  |> set(key: \"_field\", value: \"a\")\n\nmatched = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"edges\" and r[\"_field\"] == \"delay_ns\")\n  |> aggregateWindow(every: 10s, fn: count, createEmpty: false)\n  |> set(key: \"_field\", value: \"m\")\n\nunion(tables: [a_count, matched])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({_time: r._time, _value: (if exists r.a then r.a else 0) - (if exists r.m then r.m else 0)}))\n  |> filter(fn: (r) => r._value > 0)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "b_count = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"edges\" and r[\"_field\"] == \"channel_b_ns\")\n  |> aggregateWindow(every: 10s, fn: count, createEmpty: false)\n  |> set(key: \"_field\", value: \"b\")\n\nmatched = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"edges\" and r[\"_field\"] == \"delay_ns\")\n  |> aggregateWindow(every: 10s, fn: count, createEmpty: false)\n  |> set(key: \"_field\", value: \"m\")\n\nunion(tables: [b_count, matched])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({_time: r._time, _value: (if exists r.b then r.b else 0) - (if exists r.m then r.m else 0)}))\n  |> filter(fn: (r) => r._value > 0)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"edges\" and r[\"_field\"] == \"delay_ns\")\n  |> aggregateWindow(every: 10s, fn: count, createEmpty: false)",
          "refId": "C"
        }
      ]
