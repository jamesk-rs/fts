      "title": "CRM Samples - slave1",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "samples = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"crm_stats\")\n  |> filter(fn: (r) => r[\"device\"] == \"slave1\")\n  |> filter(fn: (r) => r[\"_field\"] == \"samples\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n\nnew_samples = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"crm_stats\")\n  |> filter(fn: (r) => r[\"device\"] == \"slave1\")\n  |> filter(fn: (r) => r[\"_field\"] == \"new_samples\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n\njoin(tables: {samples: samples, new_samples: new_samples}, on: [\"_time\"])\n  |> map(fn: (r) => ({_time: r._time, _value: r._value_samples - r._value_new_samples}))\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> rename(columns: {_value: \"existing\"})",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"crm_stats\")\n  |> filter(fn: (r) => r[\"device\"] == \"slave1\")\n  |> filter(fn: (r) => r[\"_field\"] == \"new_samples\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> rename(columns: {_value: \"new\"})",
          "refId": "B"
        }
