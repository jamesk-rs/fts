      "title": "CPU Usage per Core",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "query": "from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"cpu\")\n  |> filter(fn: (r) => r[\"_field\"] == \"usage_user\" or r[\"_field\"] == \"usage_system\")\n  |> filter(fn: (r) => r[\"cpu\"] != \"cpu-total\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> pivot(rowKey: [\"_time\", \"cpu\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({r with _value: r.usage_user + r.usage_system}))\n  |> keep(columns: [\"_time\", \"_value\", \"cpu\"])\n  |> rename(columns: {cpu: \"_field\"})",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
