      "title": "CPU Total (Stacked)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "query": "from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"cpu\")\n  |> filter(fn: (r) => r[\"cpu\"] == \"cpu-total\")\n  |> filter(fn: (r) => r[\"_field\"] == \"usage_user\" or r[\"_field\"] == \"usage_system\" or r[\"_field\"] == \"usage_iowait\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({_time: r._time, _value: r._value, _field: if r._field == \"usage_user\" then \"user\" else if r._field == \"usage_system\" then \"system\" else \"iowait\"}))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])",
        "refId": "A"
      }]
    },
