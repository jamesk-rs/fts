      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"ftm\")\n  |> filter(fn: (r) => r[\"_field\"] == \"t1\" or r[\"_field\"] == \"t2\" or r[\"_field\"] == \"t3\" or r[\"_field\"] == \"t4\")\n  |> pivot(rowKey: [\"_time\", \"device\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({r with _value: (float(v: r.t2) - float(v: r.t1) + float(v: r.t3) - float(v: r.t4)) / 2000.0}))\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
