        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "query": "ticks = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"dtc_request\")\n  |> filter(fn: (r) => r[\"device\"] =~ /^${device1:regex}$/)\n  |> filter(fn: (r) => r[\"_field\"] == \"base_period\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n\nfrac = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"dtc_request\")\n  |> filter(fn: (r) => r[\"device\"] =~ /^${device1:regex}$/)\n  |> filter(fn: (r) => r[\"_field\"] == \"base_period_frac\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n\njoin(tables: {ticks: ticks, frac: frac}, on: [\"_time\", \"device\"])\n  |> map(fn: (r) => ({_time: r._time, device: r.device, _value: float(v: r._value_ticks) + float(v: r._value_frac) / 65536.0 - 20000.0}))\n  |> group(columns: [\"device\"])\n  |> keep(columns: [\"_time\", \"_value\", \"device\"])",
