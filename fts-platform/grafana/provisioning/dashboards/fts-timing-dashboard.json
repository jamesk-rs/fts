      "title": "Period Deviation from Nominal - slave1",
      "description": "Period = base_period + base_period_frac/65536 - 20000 (nominal)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "query": "ticks = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"dtc_request\")\n  |> filter(fn: (r) => r[\"device\"] == \"slave1\")\n  |> filter(fn: (r) => r[\"_field\"] == \"base_period\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n\nfrac = from(bucket: \"fts\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"dtc_request\")\n  |> filter(fn: (r) => r[\"device\"] == \"slave1\")\n  |> filter(fn: (r) => r[\"_field\"] == \"base_period_frac\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n\njoin(tables: {ticks: ticks, frac: frac}, on: [\"_time\"])\n  |> map(fn: (r) => ({_time: r._time, _value: float(v: r._value_ticks) + float(v: r._value_frac) / 65536.0 - 20000.0, _field: \"slave1\"}))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])",
        "refId": "A"
      }]
