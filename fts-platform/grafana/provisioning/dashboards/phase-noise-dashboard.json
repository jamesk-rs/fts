      "description": "Single-sideband phase noise L(f) vs offset frequency. Lower is better. Shows latest measurement.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
