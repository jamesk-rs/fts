#!/bin/bash
# FTS Platform Docker Compose wrapper
# Usage: docker {start|stop|restart|status|logs} [services...]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLATFORM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Auto-detect docker socket GID for telegraf container
export DOCKER_GID="${DOCKER_GID:-$(stat -c '%g' /var/run/docker.sock 2>/dev/null || echo 124)}"

cd "$PLATFORM_DIR"

# Source .env to get COMPOSE_PROFILES
if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# Determine compose file based on profile
COMPOSE_FILE_ARG=""
if [ "$COMPOSE_PROFILES" = "split-local" ]; then
    COMPOSE_FILE_ARG="-f docker-compose.split-local.yml"
fi

cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
    start|up)
        echo "Starting FTS platform${*:+ ($*)}..."
        docker compose $COMPOSE_FILE_ARG up -d "$@"
        ;;
    stop|down)
        echo "Stopping FTS platform${*:+ ($*)}..."
        docker compose $COMPOSE_FILE_ARG down "$@"
        ;;
    restart)
        echo "Restarting FTS platform${*:+ ($*)}..."
        docker compose $COMPOSE_FILE_ARG up -d --build "$@"
        ;;
    status|ps)
        docker compose $COMPOSE_FILE_ARG ps "$@"
        ;;
    logs)
        docker compose $COMPOSE_FILE_ARG logs "$@"
        ;;
    *)
        echo "Usage: $(basename "$0") {start|stop|restart|status|logs} [services...]"
        echo ""
        echo "Commands:"
        echo "  start   [svc...]  - Start services (default: all)"
        echo "  stop    [svc...]  - Stop services (default: all)"
        echo "  restart [svc...]  - Restart services (default: all)"
        echo "  status  [svc...]  - Show service status"
        echo "  logs    [svc...]  - Show logs (supports -f, --tail, etc.)"
        echo ""
        echo "Services: mosquitto, influxdb, telegraf, redis, grafana, rl_engine"
        echo ""
        echo "Examples:"
        echo "  $(basename "$0") start"
        echo "  $(basename "$0") restart telegraf"
        echo "  $(basename "$0") logs telegraf -f --tail 100"
        exit 1
        ;;
esac
