#!/bin/bash
# FTS Experiment Tracking
# Usage: experiment {start|event|stop|status|list} [args...]
#
# Stores experiment annotations in InfluxDB for correlation with time-series data.
# See docs/EXPERIMENTS.md for design details.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# Load .env file if it exists
if [ -f "$PROJECT_DIR/.env" ]; then
    set -a
    source "$PROJECT_DIR/.env"
    set +a
fi

# InfluxDB configuration
# For split-local: use cloud server (same as MQTT bridge host)
# For local: use localhost
if [ -n "$INFLUX_URL" ]; then
    INFLUX_URL="$INFLUX_URL"
elif [ -n "$MQTT_BRIDGE_HOST" ]; then
    # Split setup - InfluxDB is on cloud
    INFLUX_URL="http://${MQTT_BRIDGE_HOST}:8086"
else
    # Local setup
    INFLUX_URL="http://localhost:8086"
fi

INFLUX_TOKEN="${INFLUX_TOKEN:-${INFLUX_ADMIN_TOKEN:-changeme}}"
INFLUX_ORG="${INFLUX_ORG:-fts}"
INFLUX_BUCKET="${INFLUX_BUCKET:-fts}"
STATE_FILE="/tmp/fts-experiment-current"

# Validate that a string doesn't contain backslashes
check_no_backslash() {
    local value="$1"
    local name="$2"
    if [[ "$value" == *\\* ]]; then
        echo "Error: $name cannot contain backslashes: $value" >&2
        exit 1
    fi
}

# Debug: show config if -v flag
if [ "$1" = "-v" ] || [ "$1" = "--verbose" ]; then
    echo "InfluxDB URL: $INFLUX_URL"
    echo "InfluxDB Org: $INFLUX_ORG"
    echo "InfluxDB Bucket: $INFLUX_BUCKET"
    shift
fi

write_event() {
    local experiment="$1"
    local event_type="$2"
    local description="$3"
    local timestamp_ns=$(date +%s%N)

    # Escape special characters in description for line protocol
    # Only need to escape backslashes and quotes since value is inside double quotes
    description=$(echo "$description" | sed 's/\\/\\\\/g' | sed 's/"/\\"/g')

    # Write to InfluxDB using line protocol
    local response
    response=$(curl -s -w "\n%{http_code}" -X POST "${INFLUX_URL}/api/v2/write?org=${INFLUX_ORG}&bucket=${INFLUX_BUCKET}&precision=ns" \
        -H "Authorization: Token ${INFLUX_TOKEN}" \
        -H "Content-Type: text/plain" \
        -d "experiments,experiment=${experiment},type=${event_type} description=\"${description}\" ${timestamp_ns}" 2>&1)

    local http_code=$(echo "$response" | tail -1)
    local body=$(echo "$response" | head -n -1)

    if [ "$http_code" != "204" ] && [ "$http_code" != "200" ]; then
        echo "Error writing to InfluxDB (HTTP $http_code): $body" >&2
        echo "URL: $INFLUX_URL" >&2
        return 1
    fi
}

query_influx() {
    local query="$1"
    curl -s -X POST "${INFLUX_URL}/api/v2/query?org=${INFLUX_ORG}" \
        -H "Authorization: Token ${INFLUX_TOKEN}" \
        -H "Content-Type: application/vnd.flux" \
        -H "Accept: application/csv" \
        -d "$query"
}

cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
    start)
        if [ -z "$1" ]; then
            echo "Usage: experiment start <name> [description]"
            exit 1
        fi
        if [ $# -gt 2 ]; then
            echo "Error: too many arguments. Usage: experiment start <name> [description]" >&2
            exit 1
        fi
        experiment_name="$1"
        description="${2:-Experiment started}"
        check_no_backslash "$experiment_name" "experiment name"
        check_no_backslash "$description" "description"

        if [ -f "$STATE_FILE" ]; then
            current=$(cat "$STATE_FILE")
            echo "Warning: Experiment '$current' is already running. Stopping it first."
            write_event "$current" "stop" "Auto-stopped (new experiment started)"
        fi

        echo "$experiment_name" > "$STATE_FILE"
        write_event "$experiment_name" "start" "$description"
        echo "Started experiment: $experiment_name"
        ;;

    event|e)
        if [ -z "$1" ]; then
            echo "Usage: experiment event <description>"
            exit 1
        fi
        if [ $# -gt 1 ]; then
            echo "Error: too many arguments. Usage: experiment event <description>" >&2
            echo "Hint: wrap description in quotes if it contains spaces" >&2
            exit 1
        fi
        description="$1"
        check_no_backslash "$description" "description"

        if [ -f "$STATE_FILE" ]; then
            experiment_name=$(cat "$STATE_FILE")
        else
            experiment_name="unnamed"
            echo "Note: No active experiment, logging as 'unnamed'"
        fi

        write_event "$experiment_name" "event" "$description"
        echo "Event logged: $description"
        ;;

    stop)
        if [ ! -f "$STATE_FILE" ]; then
            echo "No active experiment to stop"
            exit 1
        fi
        if [ $# -gt 1 ]; then
            echo "Error: too many arguments. Usage: experiment stop [description]" >&2
            exit 1
        fi

        experiment_name=$(cat "$STATE_FILE")
        description="${1:-Experiment ended}"
        check_no_backslash "$description" "description"

        write_event "$experiment_name" "stop" "$description"
        rm -f "$STATE_FILE"
        echo "Stopped experiment: $experiment_name"
        ;;

    status|s)
        if [ -f "$STATE_FILE" ]; then
            experiment_name=$(cat "$STATE_FILE")
            echo "Active experiment: $experiment_name"
        else
            echo "No active experiment"
        fi
        ;;

    list|ls)
        # Query for unique experiments with their start times
        result=$(query_influx 'from(bucket: "fts") |> range(start: -365d) |> filter(fn: (r) => r._measurement == "experiments") |> filter(fn: (r) => r.type == "start") |> keep(columns: ["_time", "experiment", "_value"]) |> group(columns: ["experiment"]) |> sort(columns: ["_time"], desc: true) |> first()')

        if echo "$result" | grep -q "unauthorized"; then
            echo "Error: Unauthorized. Check INFLUX_TOKEN in .env" >&2
            exit 1
        fi

        if echo "$result" | grep -q "error"; then
            echo "Error querying InfluxDB:" >&2
            echo "$result" >&2
            exit 1
        fi

        # Parse CSV output - columns: ,result,table,_time,_value,experiment (skip header line)
        echo "Experiments (most recent first):"
        parsed=$(echo "$result" | grep -v "^#" | grep -v "^$" | tail -n +2 | \
            awk -F',' '{ if ($6 != "" && $6 != "experiment") { t=$4; gsub(/T/, " ", t); gsub(/Z/, "", t); sub(/\.[0-9]+/, "", t); print "  " t "  " $6 } }' | sort -r | head -20)

        if [ -n "$parsed" ]; then
            echo "$parsed"
        else
            echo "  (no experiments found)"
        fi
        ;;

    show)
        if [ -z "$1" ]; then
            echo "Usage: experiment show <name>"
            exit 1
        fi
        if [ $# -gt 1 ]; then
            echo "Error: too many arguments. Usage: experiment show <name>" >&2
            exit 1
        fi
        experiment_name="$1"

        # Query all events for this experiment
        result=$(query_influx "from(bucket: \"fts\") |> range(start: -365d) |> filter(fn: (r) => r._measurement == \"experiments\") |> filter(fn: (r) => r.experiment == \"${experiment_name}\") |> keep(columns: [\"_time\", \"type\", \"_value\"]) |> sort(columns: [\"_time\"])")

        # CSV columns: ,result,table,_time,_value,type (skip header line)
        echo "Events for experiment '$experiment_name':"
        echo "$result" | grep -v "^#" | grep -v "^$" | tail -n +2 | \
            awk -F',' '{ if ($6 != "" && $6 != "type") { t=$4; gsub(/T/, " ", t); gsub(/Z/, "", t); sub(/\.[0-9]+/, "", t); d=$5; gsub(/\\/, "", d); print "  " t "  [" $6 "] " d } }'
        ;;

    *)
        echo "FTS Experiment Tracking"
        echo ""
        echo "Usage: $(basename "$0") [-v] <command> [args...]"
        echo ""
        echo "Commands:"
        echo "  start <name> [desc]  - Start a new experiment"
        echo "  event <description>  - Log an event in current experiment"
        echo "  stop [description]   - Stop current experiment"
        echo "  status               - Show current experiment"
        echo "  list                 - List all experiments"
        echo "  show <name>          - Show events for an experiment"
        echo ""
        echo "Options:"
        echo "  -v, --verbose        - Show configuration before running"
        echo ""
        echo "Shortcuts: e=event, s=status, ls=list"
        echo ""
        echo "Configuration (via .env or environment):"
        echo "  INFLUX_URL           - InfluxDB URL (auto-detected from MQTT_BRIDGE_HOST)"
        echo "  INFLUX_TOKEN         - InfluxDB API token"
        echo "  INFLUX_ORG           - InfluxDB organization (default: fts)"
        echo "  INFLUX_BUCKET        - InfluxDB bucket (default: fts)"
        echo ""
        echo "Examples:"
        echo "  $(basename "$0") start distance-test-001 'Testing range limits'"
        echo "  $(basename "$0") event 'all devices on desktop'"
        echo "  $(basename "$0") e 'master moved 10m away'"
        echo "  $(basename "$0") stop"
        echo "  $(basename "$0") list"
        echo "  $(basename "$0") show distance-test-001"
        exit 1
        ;;
esac
